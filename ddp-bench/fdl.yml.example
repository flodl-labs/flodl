description: DDP validation and benchmark suite
docker: cuda
entry: cargo run --release --features cuda --

# Interim hand-written schema. Drives `fdl ddp-bench --help` rendering and
# (once completions land) tab-completion. Will be replaced by the binary's
# own `--fdl-schema` output in the next rollout step.
schema:
  options:
    model:
      type: string
      short: m
      description: Run a specific model (or "all" for every registered model)
      default: all
      choices: [logistic, mlp, lenet, resnet, resnet-graph, char-rnn, gpt-nano, conv-ae, all]
    mode:
      type: string
      description: Run a specific DDP mode (or "all" for every mode)
      default: solo-0
      choices: [solo-0, solo-1, nccl-sync, nccl-cadence, nccl-async, cpu-sync, cpu-cadence, cpu-async, all]
    epochs:
      type: int
      description: Override epoch count (default comes from training.epochs)
    batches:
      type: int
      description: Batches per epoch (default = full epoch)
    batch-size:
      type: int
      description: Batch size per GPU
    lr-scale:
      type: float
      description: Multiply default LR (auto-scales when epochs > 5)
    output:
      type: path
      description: Output directory for runs and timelines
      default: runs
    data-dir:
      type: path
      description: Dataset cache directory
      default: data
    monitor:
      type: int
      description: Live dashboard port (omit to disable)
    validate:
      type: bool
      description: Check results against baselines
    save-baseline:
      type: bool
      description: Save results as the new baseline
    baseline:
      type: path
      description: Baseline JSON file
      default: baselines/baseline.json
    tolerance:
      type: float
      description: Validation tolerance (0.0-1.0 relative)
      default: 0.15
    seed:
      type: int
      description: RNG seed
      default: 42
    list:
      type: bool
      description: Show available models and modes, then exit
    report:
      type: path
      description: Analyze saved runs and write a markdown report (skips training). Use "-" for stdout.
      default: runs/report.md

# Default LRs per model (for reference):
#   linear=0.001  mlp=0.001  convnet=0.001  lstm=0.001
#   transformer=0.0005  autoencoder=0.001  residual=0.0003
#   moe=0.001  feedback=0.001
# LR auto-scales when --epochs > 5: lr = default * (5 / epochs)
# Override with --lr-scale <F> to multiply all LRs explicitly.
training:
  epochs: 5
  seed: 42

output:
  dir: runs/

commands:
  quick:
    description: Fast smoke test (linear, 1 epoch)
    training: { epochs: 1 }
    options: { model: linear, mode: solo-0, batches: 100 }

  full-sweep:
    description: All models, all DDP modes
    options: { model: all, mode: all }

  solo-0:
    description: Solo baseline on fast GPU (all models)
    options: { model: all, mode: solo-0 }

  solo-1:
    description: Solo baseline on slow GPU (all models)
    options: { model: all, mode: solo-1 }

  nccl-async:
    description: NCCL async for all models
    options: { model: all, mode: nccl-async }

  nccl-cadence:
    description: NCCL cadence for all models
    options: { model: all, mode: nccl-cadence }

  validate:
    description: Check convergence against structured baselines
    options: { model: all, mode: all, validate: true, baseline: baselines/structured.json }

  report:
    description: Generate convergence report from timeline data
    options: { report: runs/report.md }
