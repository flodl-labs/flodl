description: flodl-hf — HuggingFace integration (safetensors, hub, parity fixtures)

commands:
  convert:
    description: Convert a Hub repo's pytorch_model.bin to model.safetensors for flodl-hf
    path: ./convert/

  parity-bert:
    description: Regenerate tests/fixtures/bert_base_uncased_parity.safetensors against HuggingFace reference
    run: python scripts/parity_bert.py
    docker: hf-parity

  parity-bert-seqcls:
    description: Regenerate tests/fixtures/bert_seqcls_parity.safetensors (BertForSequenceClassification)
    # The emotion checkpoint is .bin-only; convert to safetensors into the
    # flodl-converted cache first so from_pretrained picks it up for the
    # matching _live test.
    run: python scripts/convert_bin_to_safetensors.py nateraw/bert-base-uncased-emotion && python scripts/parity_bert_seqcls.py
    docker: hf-parity

  parity-bert-tokencls:
    description: Regenerate tests/fixtures/bert_tokencls_parity.safetensors (BertForTokenClassification)
    run: python scripts/parity_bert_tokencls.py
    docker: hf-parity

  parity-bert-qa:
    description: Regenerate tests/fixtures/bert_qa_parity.safetensors (BertForQuestionAnswering)
    run: python scripts/parity_bert_qa.py
    docker: hf-parity

  parity-bert-mlm:
    description: Regenerate tests/fixtures/bert_mlm_parity.safetensors (BertForMaskedLM)
    run: python scripts/parity_bert_mlm.py
    docker: hf-parity

  parity-roberta:
    description: Regenerate tests/fixtures/roberta_base_parity.safetensors against HuggingFace reference
    run: python scripts/parity_roberta.py
    docker: hf-parity

  parity-roberta-seqcls:
    description: Regenerate tests/fixtures/roberta_seqcls_parity.safetensors (RobertaForSequenceClassification)
    # The cardiffnlp sentiment checkpoint ships only `pytorch_model.bin`;
    # convert to safetensors first so from_pretrained picks it up for the
    # matching _live test.
    run: python scripts/convert_bin_to_safetensors.py cardiffnlp/twitter-roberta-base-sentiment-latest && python scripts/parity_roberta_seqcls.py
    docker: hf-parity

  parity-roberta-tokencls:
    description: Regenerate tests/fixtures/roberta_tokencls_parity.safetensors (RobertaForTokenClassification)
    run: python scripts/parity_roberta_tokencls.py
    docker: hf-parity

  parity-roberta-qa:
    description: Regenerate tests/fixtures/roberta_qa_parity.safetensors (RobertaForQuestionAnswering)
    run: python scripts/parity_roberta_qa.py
    docker: hf-parity

  parity-roberta-mlm:
    description: Regenerate tests/fixtures/roberta_mlm_parity.safetensors (RobertaForMaskedLM)
    run: python scripts/parity_roberta_mlm.py
    docker: hf-parity

  parity-distilbert:
    description: Regenerate tests/fixtures/distilbert_base_parity.safetensors against HuggingFace reference
    run: python scripts/parity_distilbert.py
    docker: hf-parity

  parity-distilbert-seqcls:
    description: Regenerate tests/fixtures/distilbert_seqcls_parity.safetensors (DistilBertForSequenceClassification)
    run: python scripts/parity_distilbert_seqcls.py
    docker: hf-parity

  parity-distilbert-tokencls:
    description: Regenerate tests/fixtures/distilbert_tokencls_parity.safetensors (DistilBertForTokenClassification)
    run: python scripts/parity_distilbert_tokencls.py
    docker: hf-parity

  parity-distilbert-qa:
    description: Regenerate tests/fixtures/distilbert_qa_parity.safetensors (DistilBertForQuestionAnswering)
    run: python scripts/parity_distilbert_qa.py
    docker: hf-parity

  parity-distilbert-mlm:
    description: Regenerate tests/fixtures/distilbert_mlm_parity.safetensors (DistilBertForMaskedLM)
    run: python scripts/parity_distilbert_mlm.py
    docker: hf-parity

  parity-albert:
    description: Regenerate tests/fixtures/albert_base_v2_parity.safetensors against HuggingFace reference
    run: python scripts/parity_albert.py
    docker: hf-parity

  parity-xlm-roberta:
    description: Regenerate tests/fixtures/xlm_roberta_base_parity.safetensors against HuggingFace reference (FLORES-200 multilingual prompt)
    run: python scripts/parity_xlm_roberta.py
    docker: hf-parity

  parity-deberta-v2:
    description: Regenerate tests/fixtures/deberta_v2_parity.safetensors against HuggingFace reference (microsoft/deberta-v3-base)
    run: python scripts/parity_deberta_v2.py
    docker: hf-parity

  export:
    description: Export a Hub repo as a HuggingFace-compatible directory for AutoModel.from_pretrained (model.safetensors + config.json via flodl's own writer)
    path: ./export/

  verify-export:
    description: Verify a flodl export by loading it through HF AutoModelFor* and forwarding bit-exact vs the Hub source. Auto-detects family + head from <dir>/config.json (model_type + architectures[0]). Stage first with `fdl flodl-hf export --hub <repo> --out <dir>`.
    path: ./verify-export/

  verify-export-bert:
    description: Smoke-test wrapper — verify an export of bert-base-uncased. Stage first with `fdl flodl-hf export --hub bert-base-uncased --out flodl-hf/tests/.exports/bert`.
    run: python scripts/verify_export.py flodl-hf/tests/.exports/bert --hub-source bert-base-uncased
    docker: hf-parity

  verify-export-roberta:
    description: Smoke-test wrapper — verify an export of roberta-base. Stage first with `fdl flodl-hf export --hub roberta-base --out flodl-hf/tests/.exports/roberta`.
    run: python scripts/verify_export.py flodl-hf/tests/.exports/roberta --hub-source roberta-base
    docker: hf-parity

  verify-export-distilbert:
    description: Smoke-test wrapper — verify an export of distilbert-base-uncased. Stage first with `fdl flodl-hf export --hub distilbert/distilbert-base-uncased --out flodl-hf/tests/.exports/distilbert`.
    run: python scripts/verify_export.py flodl-hf/tests/.exports/distilbert --hub-source distilbert/distilbert-base-uncased
    docker: hf-parity

  verify-export-xlm-roberta:
    description: Smoke-test wrapper — verify an export of xlm-roberta-base. Stage first with `fdl flodl-hf export --hub FacebookAI/xlm-roberta-base --out flodl-hf/tests/.exports/xlm-roberta`.
    run: python scripts/verify_export.py flodl-hf/tests/.exports/xlm-roberta --hub-source FacebookAI/xlm-roberta-base
    docker: hf-parity

  verify-export-albert:
    description: Smoke-test wrapper — verify an export of albert-base-v2. Stage first with `fdl flodl-hf export --hub albert/albert-base-v2 --out flodl-hf/tests/.exports/albert`.
    run: python scripts/verify_export.py flodl-hf/tests/.exports/albert --hub-source albert/albert-base-v2
    docker: hf-parity

  verify-export-deberta-v2:
    description: Smoke-test wrapper — verify an export of deberta-v3-base. Stage first with `fdl flodl-hf export --hub microsoft/deberta-v3-base --out flodl-hf/tests/.exports/deberta-v2`.
    run: python scripts/verify_export.py flodl-hf/tests/.exports/deberta-v2 --hub-source microsoft/deberta-v3-base
    docker: hf-parity

  example:
    description: Runnable examples (see `fdl flodl-hf example` for the list)
    path: ./examples/
