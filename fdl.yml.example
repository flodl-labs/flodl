description: flodl - Rust deep learning framework

commands:
  # --- Sub-command (child fdl.yml) ---
  ddp-bench:                    # convention: ./ddp-bench/fdl.yml
  flodl-hf:                     # convention: ./flodl-hf/fdl.yml

  # --- CPU targets ---
  build:
    description: Build (debug)
    run: cargo build
    docker: dev
  test:
    description: Run all CPU tests
    run: cargo test
    append: -- --nocapture
    docker: dev
  test-release:
    description: Run tests in release mode
    run: cargo test --release
    append: -- --nocapture
    docker: dev
  test-live:
    description: Run live tests (network / external resources; `#[ignore]` + name ending in `_live`)
    run: cargo test live
    append: -- --nocapture --ignored
    docker: dev
  check:
    description: Type check without building
    run: cargo check
    docker: dev
  clippy:
    description: Lint (including test code, workspace + ddp-bench)
    run: cargo clippy --tests -- -W clippy::all && cd ddp-bench && cargo clippy --tests -- -W clippy::all
    docker: dev
  doc:
    description: Generate API docs (strict, fails on warnings)
    run: RUSTDOCFLAGS="-D warnings" cargo doc --no-deps --document-private-items && test -f target/doc/flodl/index.html
    docker: dev
  ci:
    description: Run the full CI CPU job locally (build + test + clippy + doc)
    run: cargo build && cargo test -- --nocapture && cargo clippy -- -W clippy::all && RUSTDOCFLAGS="-D warnings" cargo doc --no-deps --document-private-items && test -f target/doc/flodl/index.html
    docker: dev
  shell:
    description: Interactive shell in dev container
    run: bash
    docker: dev

  # --- CUDA targets ---
  cuda-build:
    description: Build with CUDA feature
    run: cargo build --features cuda
    docker: cuda
  cuda-test:
    description: Run CUDA tests (parallel, excludes NCCL/Graph)
    run: cargo test --features cuda
    append: -- --nocapture
    docker: cuda
  cuda-test-all:
    description: Full CUDA suite (parallel + NCCL isolated + serial)
    run: cargo test --features cuda -- --nocapture && cargo test --features cuda -- --nocapture --ignored --test-threads=1 nccl && cargo test --features cuda -- --nocapture --ignored --test-threads=1 graph_distribute && cargo test --features cuda -- --nocapture --ignored --test-threads=1 --skip nccl --skip graph_distribute --skip _live
    docker: cuda
  cuda-test-nccl:
    description: NCCL/DDP tests only (isolated processes)
    run: cargo test --features cuda -- --nocapture --ignored --test-threads=1 nccl && cargo test --features cuda -- --nocapture --ignored --test-threads=1 graph_distribute
    docker: cuda
  cuda-test-serial:
    description: Serial CUDA tests (Graphs, manual_seed, probes)
    run: cargo test --features cuda -- --nocapture --ignored --test-threads=1 --skip nccl --skip graph_distribute --skip _live
    docker: cuda
  cuda-test-graph:
    description: CUDA Graph tests only (exclusive GPU, single-threaded)
    run: cargo test --features cuda -- --nocapture --ignored --test-threads=1 cuda_graph
    docker: cuda
  cuda-clippy:
    description: Lint with CUDA feature (including tests, workspace + ddp-bench)
    run: cargo clippy --features cuda --tests -- -W clippy::all && cd ddp-bench && cargo clippy --tests --features cuda -- -W clippy::all
    docker: cuda
  cuda-shell:
    description: Interactive shell in CUDA container
    run: bash
    docker: cuda

  # --- Benchmarks (see ./benchmarks/fdl.yml) ---
  bench:
    path: ./benchmarks/

  # --- fdl CLI ---
  self-build:
    description: Rebuild fdl CLI after changes
    run: cargo install --path flodl-cli
